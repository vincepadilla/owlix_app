{
  "expo": {
    "name": "Owlix",
    "slug": "owlix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/owlix-logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0F2C",
    "splash": {
      "backgroundColor": "#0A0F2C",
      "image": "./assets/owlix-logo.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.owlix.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0F2C",
        "foregroundImage": "./assets/owlix-logo.png"
      },
      "package": "com.owlix.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-document-picker",
      [
        "expo-file-system",
        {}
      ]
    ]
  }
}
